DATABASE_URL="postgresql://jamhub:jamhub_secret@localhost:5433/jamhub"
REDIS_URL="redis://localhost:6379"

JWT_SECRET="change-this-to-a-long-random-string-min-32-chars"
JWT_REFRESH_SECRET="change-this-to-another-long-random-string-min-32-chars"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin_secret"
MINIO_BUCKET="jamhub"
MINIO_PUBLIC_URL="http://localhost:9000/jamhub"

RESEND_API_KEY="re_your_api_key"
EMAIL_FROM="JamHub <no-reply@yourdomain.com>"

FRONTEND_URL="http://localhost:3000"
PORT=4000
NODE_ENV="development"