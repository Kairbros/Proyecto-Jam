# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=jamhub
POSTGRES_PASSWORD=jamhub_secret
POSTGRES_DB=jamhub

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_in_production_use_a_random_32char_string

# Optional: Resend API key for emails (forgot-password flow)
RESEND_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
# URL the BROWSER uses to reach the backend API.
# Local dev:        http://localhost:4000
# Remote server:    https://api.tudominio.com
#
# ⚠️  This is baked into the frontend image at build time.
#     Changing it requires rebuilding the frontend:
#     docker compose build --build-arg NEXT_PUBLIC_API_URL=https://api.tudominio.com frontend
NEXT_PUBLIC_API_URL=http://localhost:4000
